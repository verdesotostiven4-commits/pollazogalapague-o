# Variables públicas usadas por la aplicación web (obligatorias)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_PUBLICA_ANON_O_PUBLISHABLE

# Variables del servidor de Vercel (obligatorias para pedidos, métricas y paneles)
# La URL y la clave privada deben pertenecer al MISMO proyecto de Supabase.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_O_SECRET_KEY

# Alias admitidos por el servidor, por si Supabase muestra las claves nuevas:
# SUPABASE_SECRET_KEY=sb_secret_...
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Opcional: secreto separado para firmar las sesiones del panel.
# POLLAZO_PANEL_SESSION_SECRET=una-frase-aleatoria-de-mas-de-32-caracteres
