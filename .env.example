# Frontend público: solo la clave anon de Supabase puede usar prefijo VITE_.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# Servidor: acceso privado a Supabase para endpoints administrativos.
# SUPABASE_URL puede ser igual a VITE_SUPABASE_URL, pero no lleva prefijo VITE_.
# La service role jamás debe exponerse al navegador ni incluirse en commits.
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY_PRIVADA

# Paneles privados: configurar únicamente como variables de servidor en Vercel.
# No usar prefijo VITE_ y no copiar valores reales dentro del repositorio.
POLLAZO_ADMIN_PIN=CAMBIA_ESTE_PIN
POLLAZO_DELIVERY_PIN=CAMBIA_ESTE_PIN

# Secretos aleatorios de al menos 32 caracteres para cookies HttpOnly.
# Deben ser distintos entre sí, distintos de ambos PIN y permanecer solo en Vercel.
POLLAZO_PANEL_SESSION_SECRET=REEMPLAZA_CON_UN_SECRETO_ALEATORIO_DE_32_CARACTERES_O_MAS
POLLAZO_CUSTOMER_SESSION_SECRET=REEMPLAZA_CON_OTRO_SECRETO_ALEATORIO_DE_32_CARACTERES_O_MAS

# Solo para desarrollo local y únicamente durante una transición controlada.
# En producción debe permanecer ausente o false.
VITE_ALLOW_LEGACY_ORDER_INSERT=false
