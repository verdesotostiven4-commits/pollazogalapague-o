# Frontend público: solo la clave anon de Supabase puede usar prefijo VITE_.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# Paneles privados: configurar únicamente como variables de servidor en Vercel.
# No usar prefijo VITE_ y no copiar valores reales dentro del repositorio.
POLLAZO_ADMIN_PIN=CAMBIA_ESTE_PIN
POLLAZO_DELIVERY_PIN=CAMBIA_ESTE_PIN

# Secreto aleatorio de al menos 32 caracteres para firmar cookies HttpOnly.
# Debe ser distinto de ambos PIN y permanecer solo en Vercel.
POLLAZO_PANEL_SESSION_SECRET=REEMPLAZA_CON_UN_SECRETO_ALEATORIO_DE_32_CARACTERES_O_MAS
